<div id="app-shell" class="min-h-screen bg-zinc-100 flex" phx-hook="Sidebar" phx-window-keydown="global_keydown">
  <%!-- Mobile overlay backdrop --%>
  <div id="mobile-sidebar-overlay" class="fixed inset-0 bg-black/40 z-30 hidden md:hidden" data-role="mobile-overlay"></div>
  <aside id="app-sidebar" class="hidden md:flex w-64 bg-zinc-900 text-zinc-200 flex-col fixed md:static inset-y-0 left-0 z-40">
    <div class="h-14 border-b border-zinc-800 px-4 flex items-center justify-between">
      <span class="font-semibold sidebar-label">Jido Builder</span>
      <button id="sidebar-toggle" data-role="sidebar-toggle" class="text-xs text-zinc-400 hover:text-zinc-200 transition-colors">
        <.icon name="chevron_left" class="w-4 h-4 sidebar-expanded-only" />
        <.icon name="chevron_right" class="w-4 h-4 sidebar-collapsed-only hidden" />
      </button>
    </div>
    <nav class="flex-1 overflow-y-auto p-3 text-sm space-y-3">
      <%
        cur = assigns[:current_path] || ""
        active = "flex items-center px-2 py-1.5 rounded bg-zinc-800 text-white"
        inactive = "flex items-center px-2 py-1.5 rounded text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800 transition-colors"
      %>
      <%!-- ── OPERATE ── --%>
      <section>
        <p class="sidebar-label text-zinc-500 text-[10px] uppercase tracking-wider font-medium mb-1">Operate</p>
        <.link navigate={~p"/"} class={if cur == "/", do: active, else: inactive}>
          <.icon name="home" class="w-4 h-4 mr-2" /><span class="sidebar-label">Dashboard</span>
        </.link>
        <.link navigate={~p"/roster"} class={if String.starts_with?(cur, "/roster") || String.starts_with?(cur, "/agents"), do: active, else: inactive}>
          <.icon name="users" class="w-4 h-4 mr-2" /><span class="sidebar-label">Agents</span>
        </.link>
        <.link navigate={~p"/assignments/new"} class={if String.starts_with?(cur, "/assignments"), do: active, else: inactive}>
          <.icon name="signal" class="w-4 h-4 mr-2" /><span class="sidebar-label">Dispatch Signal</span>
        </.link>
        <.link navigate={~p"/workflows"} class={if String.starts_with?(cur, "/workflow"), do: active, else: inactive}>
          <.icon name="play" class="w-4 h-4 mr-2" /><span class="sidebar-label">Workflows</span>
        </.link>
        <.link navigate={~p"/schedules"} class={if String.starts_with?(cur, "/schedule"), do: active, else: inactive}>
          <.icon name="clock" class="w-4 h-4 mr-2" /><span class="sidebar-label">Schedules</span>
        </.link>
      </section>

      <%!-- ── CONFIGURE ── --%>
      <section>
        <p class="sidebar-label text-zinc-500 text-[10px] uppercase tracking-wider font-medium mb-1">Configure</p>
        <.link navigate={~p"/templates"} class={if String.starts_with?(cur, "/templates"), do: active, else: inactive}>
          <.icon name="document" class="w-4 h-4 mr-2" /><span class="sidebar-label">Templates</span>
        </.link>
        <.link navigate={~p"/skills"} class={if cur == "/skills", do: active, else: inactive}>
          <.icon name="beaker" class="w-4 h-4 mr-2" /><span class="sidebar-label">Skills</span>
        </.link>
        <.link navigate={~p"/directives"} class={if String.starts_with?(cur, "/directive"), do: active, else: inactive}>
          <.icon name="bolt" class="w-4 h-4 mr-2" /><span class="sidebar-label">Directives</span>
        </.link>
        <.link navigate={~p"/teams"} class={if String.starts_with?(cur, "/teams"), do: active, else: inactive}>
          <.icon name="user_group" class="w-4 h-4 mr-2" /><span class="sidebar-label">Teams</span>
        </.link>
        <.link navigate={~p"/identity"} class={if String.starts_with?(cur, "/identity"), do: active, else: inactive}>
          <.icon name="user" class="w-4 h-4 mr-2" /><span class="sidebar-label">Identity</span>
        </.link>
        <.link navigate={~p"/work-styles"} class={if String.starts_with?(cur, "/work-styles"), do: active, else: inactive}>
          <.icon name="puzzle_piece" class="w-4 h-4 mr-2" /><span class="sidebar-label">Work Styles</span>
        </.link>
        <.link navigate={~p"/skills-manager"} class={if String.starts_with?(cur, "/skills-manager"), do: active, else: inactive}>
          <.icon name="beaker" class="w-4 h-4 mr-2" /><span class="sidebar-label">Skills Manager</span>
        </.link>
        <.link navigate={~p"/llm-config"} class={if String.starts_with?(cur, "/llm-config"), do: active, else: inactive}>
          <.icon name="cpu_chip" class="w-4 h-4 mr-2" /><span class="sidebar-label">LLM Config</span>
        </.link>
      </section>

      <%!-- ── BUILD ── --%>
      <section>
        <p class="sidebar-label text-zinc-500 text-[10px] uppercase tracking-wider font-medium mb-1">Build</p>
        <.link navigate={~p"/blocks"} class={if String.starts_with?(cur, "/blocks") || String.starts_with?(cur, "/editor"), do: active, else: inactive}>
          <.icon name="cube" class="w-4 h-4 mr-2" /><span class="sidebar-label">Blocks</span>
        </.link>
        <.link navigate={~p"/state-ops"} class={if String.starts_with?(cur, "/state-ops"), do: active, else: inactive}>
          <.icon name="command_line" class="w-4 h-4 mr-2" /><span class="sidebar-label">State Ops</span>
        </.link>
        <.link navigate={~p"/hierarchy"} class={if String.starts_with?(cur, "/hierarchy"), do: active, else: inactive}>
          <.icon name="arrow_path" class="w-4 h-4 mr-2" /><span class="sidebar-label">Hierarchy</span>
        </.link>
        <.link navigate={~p"/pools"} class={if String.starts_with?(cur, "/pools"), do: active, else: inactive}>
          <.icon name="circle_stack" class="w-4 h-4 mr-2" /><span class="sidebar-label">Pools</span>
        </.link>
        <.link navigate={~p"/threads"} class={if String.starts_with?(cur, "/threads"), do: active, else: inactive}>
          <.icon name="chat_bubble_left_right" class="w-4 h-4 mr-2" /><span class="sidebar-label">Threads</span>
        </.link>
        <.link navigate={~p"/memory"} class={if String.starts_with?(cur, "/memory"), do: active, else: inactive}>
          <.icon name="cpu_chip" class="w-4 h-4 mr-2" /><span class="sidebar-label">Memory</span>
        </.link>
        <.link navigate={~p"/notebook"} class={if String.starts_with?(cur, "/notebook"), do: active, else: inactive}>
          <.icon name="document" class="w-4 h-4 mr-2" /><span class="sidebar-label">Notebook</span>
        </.link>
        <.link navigate={~p"/factory"} class={if String.starts_with?(cur, "/factory"), do: active, else: inactive}>
          <.icon name="wrench_screwdriver" class="w-4 h-4 mr-2" /><span class="sidebar-label">Factory</span>
        </.link>
      </section>

      <%!-- ── OBSERVE ── --%>
      <section>
        <p class="sidebar-label text-zinc-500 text-[10px] uppercase tracking-wider font-medium mb-1">Observe</p>
        <.link navigate={~p"/execution"} class={if String.starts_with?(cur, "/execution"), do: active, else: inactive}>
          <.icon name="chart_bar" class="w-4 h-4 mr-2" /><span class="sidebar-label">Execution</span>
        </.link>
        <.link navigate={~p"/traces"} class={if String.starts_with?(cur, "/traces"), do: active, else: inactive}>
          <.icon name="eye" class="w-4 h-4 mr-2" /><span class="sidebar-label">Traces</span>
        </.link>
        <.link navigate={~p"/audit"} class={if String.starts_with?(cur, "/audit"), do: active, else: inactive}>
          <.icon name="shield" class="w-4 h-4 mr-2" /><span class="sidebar-label">Audit</span>
        </.link>
        <.link navigate={~p"/debug"} class={if String.starts_with?(cur, "/debug"), do: active, else: inactive}>
          <.icon name="bug" class="w-4 h-4 mr-2" /><span class="sidebar-label">Debug</span>
        </.link>
        <.link navigate={~p"/active-inference"} class={if String.starts_with?(cur, "/active-inference"), do: active, else: inactive}>
          <.icon name="variable" class="w-4 h-4 mr-2" /><span class="sidebar-label">Active Inference</span>
        </.link>
        <.link navigate={~p"/metrics-dashboard"} class={if String.starts_with?(cur, "/metrics"), do: active, else: inactive}>
          <.icon name="chart_bar" class="w-4 h-4 mr-2" /><span class="sidebar-label">Metrics</span>
        </.link>
      </section>

      <%!-- ── ADMIN ── --%>
      <section>
        <p class="sidebar-label text-zinc-500 text-[10px] uppercase tracking-wider font-medium mb-1">Admin</p>
        <.link navigate={~p"/settings"} class={if String.starts_with?(cur, "/settings"), do: active, else: inactive}>
          <.icon name="cog" class="w-4 h-4 mr-2" /><span class="sidebar-label">Settings</span>
        </.link>
        <.link navigate={~p"/workspaces"} class={if String.starts_with?(cur, "/workspaces"), do: active, else: inactive}>
          <.icon name="archive_box" class="w-4 h-4 mr-2" /><span class="sidebar-label">Workspaces</span>
        </.link>
        <.link navigate={~p"/vault"} class={if String.starts_with?(cur, "/vault"), do: active, else: inactive}>
          <.icon name="folder" class="w-4 h-4 mr-2" /><span class="sidebar-label">Vault</span>
        </.link>
        <.link navigate={~p"/watchers"} class={if String.starts_with?(cur, "/watchers"), do: active, else: inactive}>
          <.icon name="eye" class="w-4 h-4 mr-2" /><span class="sidebar-label">Watchers</span>
        </.link>
        <.link navigate={~p"/error-policy"} class={if String.starts_with?(cur, "/error-policy"), do: active, else: inactive}>
          <.icon name="exclamation_triangle" class="w-4 h-4 mr-2" /><span class="sidebar-label">Error Policy</span>
        </.link>
        <.link navigate={~p"/capability-packs"} class={if String.starts_with?(cur, "/capability"), do: active, else: inactive}>
          <.icon name="puzzle_piece" class="w-4 h-4 mr-2" /><span class="sidebar-label">Capabilities</span>
        </.link>
        <.link navigate={~p"/solutions"} class={if String.starts_with?(cur, "/solutions"), do: active, else: inactive}>
          <.icon name="archive_box" class="w-4 h-4 mr-2" /><span class="sidebar-label">Solutions</span>
        </.link>
        <.link navigate={~p"/template-library"} class={if String.starts_with?(cur, "/template-library"), do: active, else: inactive}>
          <.icon name="squares_2x2" class="w-4 h-4 mr-2" /><span class="sidebar-label">Template Library</span>
        </.link>
        <.link navigate={~p"/marketplace"} class={if String.starts_with?(cur, "/marketplace"), do: active, else: inactive}>
          <.icon name="shopping_cart" class="w-4 h-4 mr-2" /><span class="sidebar-label">Marketplace</span>
        </.link>
      </section>

      <%!-- ── HELP ── --%>
      <section>
        <p class="sidebar-label text-zinc-500 text-[10px] uppercase tracking-wider font-medium mb-1">Help</p>
        <.link navigate={~p"/guide"} class={if String.starts_with?(cur, "/guide"), do: active, else: inactive}>
          <.icon name="book_open" class="w-4 h-4 mr-2" /><span class="sidebar-label">User Guide</span>
        </.link>
        <.link navigate={~p"/glossary"} class={if String.starts_with?(cur, "/glossary"), do: active, else: inactive}>
          <.icon name="search" class="w-4 h-4 mr-2" /><span class="sidebar-label">Glossary</span>
        </.link>
        <.link navigate={~p"/onboarding"} class={if String.starts_with?(cur, "/onboarding"), do: active, else: inactive}>
          <.icon name="play" class="w-4 h-4 mr-2" /><span class="sidebar-label">Onboarding</span>
        </.link>
      </section>
    </nav>
    <footer class="border-t border-zinc-800 px-3 py-2 text-[10px] text-zinc-500 space-y-1">
      <div class="flex items-center gap-1.5">
        <.icon name="cube" class="w-3 h-3" />
        <span class="sidebar-label">Jido Builder v0.1.0</span>
      </div>
      <div class="sidebar-label leading-tight">
        Built on <a href="https://www.amazon.com/ORCHESTRATE-Prompting-Professional-AI-Outputs-ebook/dp/B0G2B9LG6V" target="_blank" class="text-emerald-400 hover:underline">The ORCHESTRATE Method</a>
      </div>
      <div class="sidebar-label leading-tight">
        <a href="https://www.linkedin.com/in/mpolzin/" target="_blank" class="text-zinc-400 hover:text-emerald-400">&copy; Michael Polzin</a>
        &middot; <a href="https://iamhitl.com" target="_blank" class="text-zinc-400 hover:text-emerald-400">IAMHITL</a>
      </div>
    </footer>
  </aside>
  <div class="flex-1 min-w-0 flex flex-col">
    <header class="h-14 bg-white border-b border-zinc-200 px-4 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <button id="mobile-menu-btn" data-role="mobile-menu-toggle" class="md:hidden text-sm text-zinc-500 hover:text-zinc-700 transition-colors p-1 rounded hover:bg-zinc-100">
          <.icon name="menu" class="w-5 h-5" />
        </button>
        <button data-role="sidebar-toggle" class="hidden md:inline-flex text-sm text-zinc-500 hover:text-zinc-700 transition-colors p-1 rounded hover:bg-zinc-100">
          <.icon name="chevron_left" class="w-4 h-4" />
        </button>
      </div>
      <button id="command-palette-trigger" phx-click="toggle_palette" class="text-xs text-zinc-400 flex items-center gap-1 hover:text-zinc-600">
        <.icon name="search" class="w-3.5 h-3.5" />
        <kbd class="px-1.5 py-0.5 bg-zinc-100 rounded text-[10px] font-mono">⌘K</kbd>
      </button>
      <div class="flex items-center gap-3">
        <button :if={assigns[:view_mode]} id="view-mode-toggle" phx-click="toggle_view_mode" class="text-xs px-2 py-1 rounded bg-zinc-100 text-zinc-600 hover:bg-zinc-200">
          {if assigns[:view_mode] == "developer", do: "Developer", else: "Business"}
        </button>
        <span class="text-xs text-zinc-500"><%= @current_user.email %></span>
      </div>
    </header>
    <main class="flex-1 overflow-y-auto p-4 md:p-6">
      {@inner_content}
    </main>

    <%!-- Command Palette Overlay --%>
    <div
      :if={assigns[:palette_open]}
      id="command-palette"
      class="fixed inset-0 z-50 flex items-start justify-center pt-[15vh]"
      phx-click="close_palette"
      phx-window-keydown="close_palette"
      phx-key="Escape"
    >
      <div class="absolute inset-0 bg-black/40"></div>
      <div class="relative w-full max-w-lg bg-white rounded-xl shadow-2xl border border-zinc-200 overflow-hidden" phx-click-away="close_palette">
        <form id="palette-search-form" phx-change="palette_search" class="border-b border-zinc-200">
          <input
            id="palette-search"
            name="q"
            type="text"
            placeholder="Search pages, actions..."
            value={assigns[:palette_query] || ""}
            autofocus
            class="w-full px-4 py-3 text-sm outline-none"
            phx-debounce="100"
          />
        </form>
        <div class="max-h-80 overflow-y-auto py-2">
          <div :for={page <- assigns[:palette_results] || []} class="px-2">
            <.link navigate={page.path} class="flex items-center justify-between px-3 py-2 text-sm rounded hover:bg-zinc-100">
              <span>{page.name}</span>
              <span class="text-xs text-zinc-400">{page.section}</span>
            </.link>
          </div>
          <p :if={(assigns[:palette_results] || []) == []} class="px-4 py-3 text-sm text-zinc-400 text-center">No results</p>
        </div>
      </div>
    </div>
  </div>
</div>
